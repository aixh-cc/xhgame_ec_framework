{
  "name": "@aixh-cc/xhgame_ec_framework",
  "version": "2.2.2",
  "description": "cocos的ec框架",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.cjs"
    },
    "./min": {
      "require": "./dist/index.min.cjs",
      "import": "./dist/index.min.mjs"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "typescript",
    "cocos"
  ],
  "scripts": {
    "clean": "node -e \"const fs=require('fs');['bin','dist','tsconfig.tsbuildinfo'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}))\"",
    "build": "npm run clean && rollup -c rollup.config.mjs",
    "test": "bun test"
  },
  "author": "aixh-cc",
  "license": "MIT",
  "dependencies": {
    "crypto-js": "^4.2.0",
    "inversify": "^7.11.0",
    "inversify-inject-decorators": "^3.1.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@cocos/creator-types": "^3.8.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/bun": "^1.3.13",
    "@types/crypto-js": "^4.2.2",
    "@types/lodash": "^4.17.13",
    "@types/node": "^22.10.2",
    "node-localstorage": "^3.0.5",
    "poku": "^3.0.2",
    "rollup": "^4.28.1",
    "rollup-plugin-dts": "^6.1.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.2",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aixh-cc/xhgame_ec_framework.git"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "bugs": {
    "url": "https://github.com/aixh-cc/xhgame_ec_framework/issues"
  },
  "homepage": "https://github.com/aixh-cc/xhgame_ec_framework#readme"
}