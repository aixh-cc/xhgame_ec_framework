{
    "compilerOptions": {
        "target": "es6",
        "module": "commonjs",
        "experimentalDecorators": true,
        "strict": true,
        "strictNullChecks": false,
        "moduleResolution": "Node",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "stripInternal": true,
        "baseUrl": ".",
        "paths": {
            "@aixh-cc/xhgame_ec_framework": ["./src/index.ts"],
            "@aixh-cc/xhgame_ec_framework/*": ["./src/*"]
        },
        "types": [
            "@cocos/creator-types/engine",
            "@cocos/creator-types/editor"
        ]
    },
    "include": [
        "./src/**/*",
        "./tests/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "build"
    ]
}
